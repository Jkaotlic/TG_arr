# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram User IDs (comma-separated)
# Get your ID from @userinfobot or @raw_data_bot
ALLOWED_TG_IDS=123456789,987654321

# Admin User IDs (comma-separated, optional)
ADMIN_TG_IDS=123456789

# Prowlarr Configuration
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=your_prowlarr_api_key

# Radarr Configuration
RADARR_URL=http://radarr:7878
RADARR_API_KEY=your_radarr_api_key

# Sonarr Configuration
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=your_sonarr_api_key

# Lidarr Configuration (optional, music)
# LIDARR_URL=http://lidarr:8686
# LIDARR_API_KEY=your_lidarr_api_key

# Deezer public API (for music trending, no key required)
# DEEZER_ENABLED=true

# qBittorrent Configuration (optional)
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=your_qbittorrent_password
# QBITTORRENT_TIMEOUT=30.0

# Emby Configuration (optional)
EMBY_URL=http://emby:8096
EMBY_API_KEY=your_emby_api_key
# EMBY_TIMEOUT=30.0

# TMDb Configuration (optional, for trending/popular content)
# Get your API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key
# TMDB_LANGUAGE=ru-RU  # Language for TMDb content (ru-RU, en-US, etc.)
# TMDB_PROXY_URL=http://your-vps:8899  # HTTP proxy for TMDb (if geo-blocked)

# Download Notifications
NOTIFY_DOWNLOAD_COMPLETE=true
NOTIFY_CHECK_INTERVAL=60

# Optional Settings
TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO
# LOG_FORMAT=json  # "json" for docker logs (default) or "console" for local dev

# Database path (relative to /app in container)
DATABASE_PATH=data/bot.db

# Scoring thresholds
AUTO_GRAB_SCORE_THRESHOLD=80

# HTTP client settings
# HTTP_TIMEOUT=30.0  # HTTP request timeout in seconds

# Prowlarr search tuning (aggregates many indexers, can be slow on rpie4 Wi-Fi)
# PROWLARR_SEARCH_TIMEOUT=25.0  # seconds
# PROWLARR_SEARCH_RETRIES=1     # extra attempts on timeout (0-3)

# Pagination
# RESULTS_PER_PAGE=5  # Search results per page (1-10)

# Webhook server (optional, #8) — instant "added to library" notifications.
# When enabled, point each *arr: Settings → Connect → Webhook →
#   URL http://<pi-host>:<WEBHOOK_PORT>/webhook/<WEBHOOK_TOKEN> , POST, trigger "On Import".
# WEBHOOK_ENABLED=false
# WEBHOOK_PORT=8090
# WEBHOOK_BIND=0.0.0.0
# WEBHOOK_TOKEN=  # required shared secret when WEBHOOK_ENABLED=true
